# Netlify HTTP header rules — https://docs.netlify.com/routing/headers/
# These set the headers a <meta> tag cannot (frame-ancestors, X-Frame-Options, HSTS, etc.)
# alongside the same Content-Security-Policy already set in every page's <head>.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
